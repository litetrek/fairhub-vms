generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?
  role          Role      @default(VENDOR)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendorProfile    VendorProfile?
  sentMessages     Message[]       @relation("SentMessages")
  approvalActions  ApprovalLog[]
  documentReviews  Document[]      @relation("ReviewedDocuments")
  boothAssignments BoothAssignment[]
  payments         Payment[]       @relation("RecordedPayments")
}

enum Role {
  VENDOR
  STAFF
  ADMIN
}

model VendorProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  businessName String
  contactName  String
  businessType String?
  address      String?
  city         String?
  state        String?
  zip          String?
  website      String?
  description  String?
  createdAt    DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id])
  applications  Application[]
  documents     Document[]
  messages      Message[]
  invoices      Invoice[]
  notifications Notification[]
}

model Event {
  id             String      @id @default(uuid())
  name           String
  eventDateStart DateTime
  eventDateEnd   DateTime
  location       String?
  status         EventStatus @default(DRAFT)
  createdAt      DateTime    @default(now())

  applications Application[]
  booths       Booth[]
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

model Application {
  id                 String            @id @default(uuid())
  vendorId           String
  eventId            String
  status             ApplicationStatus @default(DRAFT)
  boothTypePref      String?
  boothSizePref      String?
  productDescription String?
  productCategory    String?
  spaceNeedsSqft     Int?
  needsElectricity   Boolean           @default(false)
  needsWater         Boolean           @default(false)
  specialRequests    String?
  submittedAt        DateTime?
  updatedAt          DateTime          @updatedAt
  createdAt          DateTime          @default(now())

  vendor       VendorProfile   @relation(fields: [vendorId], references: [id])
  event        Event           @relation(fields: [eventId], references: [id])
  documents    Document[]
  approvalLogs ApprovalLog[]
  assignment   BoothAssignment?
  invoice      Invoice?
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CONDITIONALLY_APPROVED
  APPROVED
  REJECTED
}

model Document {
  id            String         @id @default(uuid())
  vendorId      String
  applicationId String?
  docType       DocumentType
  fileName      String
  fileUrl       String
  status        DocumentStatus @default(PENDING)
  expiryDate    DateTime?
  reviewedById  String?
  uploadedAt    DateTime       @default(now())

  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  application Application?  @relation(fields: [applicationId], references: [id])
  reviewedBy  User?         @relation("ReviewedDocuments", fields: [reviewedById], references: [id])
}

enum DocumentType {
  BUSINESS_LICENSE
  SELLERS_PERMIT
  HEALTH_PERMIT
  FOOD_HANDLER
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model ApprovalLog {
  id            String   @id @default(uuid())
  applicationId String
  reviewedById  String
  action        String
  stage         String?
  notes         String?
  actionedAt    DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  reviewedBy  User        @relation(fields: [reviewedById], references: [id])
}

model Booth {
  id             String      @id @default(uuid())
  eventId        String
  boothNumber    String
  zone           String?
  size           String?
  sqft           Int?
  price          Decimal     @db.Decimal(10, 2)
  status         BoothStatus @default(AVAILABLE)
  hasElectricity Boolean     @default(false)
  hasWater       Boolean     @default(false)
  mapX           Float?
  mapY           Float?
  createdAt      DateTime    @default(now())

  event      Event            @relation(fields: [eventId], references: [id])
  assignment BoothAssignment?
}

enum BoothStatus {
  AVAILABLE
  ON_HOLD
  ASSIGNED
}

model BoothAssignment {
  id            String   @id @default(uuid())
  boothId       String   @unique
  applicationId String   @unique
  assignedById  String
  assignedAt    DateTime @default(now())
  notes         String?

  booth       Booth       @relation(fields: [boothId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  assignedBy  User        @relation(fields: [assignedById], references: [id])
  invoice     Invoice?
}

model Invoice {
  id                String        @id @default(uuid())
  vendorId          String
  applicationId     String        @unique
  boothAssignmentId String?       @unique
  invoiceNumber     String        @unique
  subtotal          Decimal       @db.Decimal(10, 2)
  tax               Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime?
  issuedAt          DateTime      @default(now())

  vendor          VendorProfile    @relation(fields: [vendorId], references: [id])
  application     Application      @relation(fields: [applicationId], references: [id])
  boothAssignment BoothAssignment? @relation(fields: [boothAssignmentId], references: [id])
  payments        Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  checkNumber     String?
  recordedById    String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  recordedBy User?   @relation("RecordedPayments", fields: [recordedById], references: [id])
}

enum PaymentMethod {
  CHECK
  ZELLE
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Message {
  id          String        @id @default(uuid())
  vendorId    String
  sentById    String?
  channel     Channel
  subject     String?
  body        String
  status      MessageStatus @default(SENT)
  templateKey String?
  sentAt      DateTime      @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
  sentBy User?         @relation("SentMessages", fields: [sentById], references: [id])
}

model Notification {
  id           String        @id @default(uuid())
  vendorId     String
  triggerEvent String
  channel      Channel
  status       MessageStatus @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
}

enum Channel {
  EMAIL
  SMS
  BOTH
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}
