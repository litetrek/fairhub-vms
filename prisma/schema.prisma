// ============================================================
// VendorHub — Prisma Schema
// Updated: Stage 3 pre-work (Pre-Event Setup support)
// Changes from previous version:
//   - Event: added description, hours, address/city/state,
//     publicSlug, bannerImageUrl, maxVendors, applicationDeadline
//   - New model: BoothType (replaces free-text boothTypePref)
//   - New model: BoothTypeDocRequirement (per-type doc rules)
//   - New model: EventWeek (selectable weeks within an event)
//   - New model: ApplicationWeek (which weeks a vendor applied for)
//   - New model: BoothAddOn (per-booth add-ons with pricing)
//   - New model: ApplicationAddOn (add-ons selected per application)
//   - Booth: simplified — no longer drives pricing (BoothType does);
//     retained for staff assignment with booth number
//   - Application: replaced boothTypePref/boothSizePref strings
//     with boothTypeId FK; added rejectionNote
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USERS & AUTH ────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?
  role          Role     @default(VENDOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendorProfile    VendorProfile?
  sentMessages     Message[]         @relation("SentMessages")
  approvalActions  ApprovalLog[]
  documentReviews  Document[]        @relation("ReviewedDocuments")
  boothAssignments BoothAssignment[]
  payments         Payment[]         @relation("RecordedPayments")
}

enum Role {
  VENDOR
  STAFF
  ADMIN
}

model VendorProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  businessName String
  contactName  String
  businessType String?
  address      String?
  city         String?
  state        String?
  zip          String?
  website      String?
  description  String?
  createdAt    DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  applications  Application[]
  documents     Document[]
  messages      Message[]
  invoices      Invoice[]
  notifications Notification[]
}

// ─── EVENT ───────────────────────────────────────────────────

model Event {
  id                  String      @id @default(uuid())
  name                String
  description         String?
  eventDateStart      DateTime
  eventDateEnd        DateTime
  hours               String?
  location            String?
  address             String?
  city                String?
  state               String?
  publicSlug          String?     @unique
  bannerImageUrl      String?
  maxVendors          Int?
  applicationDeadline DateTime?
  status              EventStatus @default(DRAFT)
  createdAt           DateTime    @default(now())

  applications Application[]
  booths       Booth[]
  boothTypes   BoothType[]
  weeks        EventWeek[]
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

// ─── EVENT WEEKS ─────────────────────────────────────────────

model EventWeek {
  id        String   @id @default(uuid())
  eventId   String
  label     String
  startDate DateTime
  endDate   DateTime
  sortOrder Int      @default(0)

  event        Event              @relation(fields: [eventId], references: [id])
  applications ApplicationWeek[]
}

// ─── BOOTH TYPES ─────────────────────────────────────────────

model BoothType {
  id           String  @id @default(uuid())
  eventId      String
  name         String
  description  String?
  basePrice    Decimal @db.Decimal(10, 2)
  sizeSqft     Int?
  totalCount   Int
  sortOrder    Int     @default(0)
  createdAt    DateTime @default(now())

  event                Event                    @relation(fields: [eventId], references: [id])
  docRequirements      BoothTypeDocRequirement[]
  applications         Application[]
}

// ─── BOOTH TYPE DOCUMENT REQUIREMENTS ────────────────────────

model BoothTypeDocRequirement {
  id          String       @id @default(uuid())
  boothTypeId String
  docType     DocumentType
  required    Boolean      @default(true)
  notes       String?

  boothType BoothType @relation(fields: [boothTypeId], references: [id])

  @@unique([boothTypeId, docType])
}

// ─── APPLICATIONS ────────────────────────────────────────────

model Application {
  id                 String            @id @default(uuid())
  vendorId           String
  eventId            String
  boothTypeId        String?
  status             ApplicationStatus @default(DRAFT)
  productDescription String?
  productCategory    String?
  needsElectricity   Boolean           @default(false)
  needsWater         Boolean           @default(false)
  specialRequests    String?
  rejectionNote      String?
  submittedAt        DateTime?
  updatedAt          DateTime          @updatedAt
  createdAt          DateTime          @default(now())

  vendor       VendorProfile    @relation(fields: [vendorId], references: [id])
  event        Event            @relation(fields: [eventId], references: [id])
  boothType    BoothType?       @relation(fields: [boothTypeId], references: [id])
  weeks        ApplicationWeek[]
  documents    Document[]
  approvalLogs ApprovalLog[]
  assignment   BoothAssignment?
  invoice      Invoice?
  addOns       ApplicationAddOn[]
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CONDITIONALLY_APPROVED
  APPROVED
  REJECTED
}

// ─── APPLICATION WEEKS ───────────────────────────────────────

model ApplicationWeek {
  id            String @id @default(uuid())
  applicationId String
  eventWeekId   String

  application Application @relation(fields: [applicationId], references: [id])
  eventWeek   EventWeek   @relation(fields: [eventWeekId], references: [id])

  @@unique([applicationId, eventWeekId])
}

// ─── DOCUMENTS ───────────────────────────────────────────────

model Document {
  id            String         @id @default(uuid())
  vendorId      String
  applicationId String?
  docType       DocumentType
  fileName      String
  fileUrl       String
  status        DocumentStatus @default(PENDING)
  expiryDate    DateTime?
  reviewedById  String?
  uploadedAt    DateTime       @default(now())

  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  application Application?  @relation(fields: [applicationId], references: [id])
  reviewedBy  User?         @relation("ReviewedDocuments", fields: [reviewedById], references: [id])
}

enum DocumentType {
  BUSINESS_LICENSE
  SELLERS_PERMIT
  HEALTH_PERMIT
  FOOD_HANDLER
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// ─── APPROVAL LOG ────────────────────────────────────────────

model ApprovalLog {
  id            String   @id @default(uuid())
  applicationId String
  reviewedById  String
  action        String
  stage         String?
  notes         String?
  actionedAt    DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  reviewedBy  User        @relation(fields: [reviewedById], references: [id])
}

// ─── BOOTHS ──────────────────────────────────────────────────

model Booth {
  id          String      @id @default(uuid())
  eventId     String
  boothNumber String
  zone        String?
  sqft        Int?
  status      BoothStatus @default(AVAILABLE)
  mapX        Float?
  mapY        Float?
  notes       String?
  createdAt   DateTime    @default(now())

  event      Event            @relation(fields: [eventId], references: [id])
  addOns     BoothAddOn[]
  assignment BoothAssignment?

  @@unique([eventId, boothNumber])
}

enum BoothStatus {
  AVAILABLE
  ON_HOLD
  ASSIGNED
}

// ─── BOOTH ADD-ONS ───────────────────────────────────────────

model BoothAddOn {
  id      String  @id @default(uuid())
  boothId String
  name    String
  price   Decimal @db.Decimal(10, 2)

  booth             Booth              @relation(fields: [boothId], references: [id])
  applicationAddOns ApplicationAddOn[]
}

// ─── APPLICATION ADD-ONS ─────────────────────────────────────

model ApplicationAddOn {
  id            String @id @default(uuid())
  applicationId String
  boothAddOnId  String
  quantity      Int    @default(1)

  application Application @relation(fields: [applicationId], references: [id])
  boothAddOn  BoothAddOn  @relation(fields: [boothAddOnId], references: [id])

  @@unique([applicationId, boothAddOnId])
}

// ─── BOOTH ASSIGNMENT ────────────────────────────────────────

model BoothAssignment {
  id            String   @id @default(uuid())
  boothId       String   @unique
  applicationId String   @unique
  assignedById  String
  assignedAt    DateTime @default(now())
  notes         String?

  booth       Booth       @relation(fields: [boothId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  assignedBy  User        @relation(fields: [assignedById], references: [id])
  invoice     Invoice?
}

// ─── INVOICES ────────────────────────────────────────────────

model Invoice {
  id                String        @id @default(uuid())
  vendorId          String
  applicationId     String        @unique
  boothAssignmentId String?       @unique
  invoiceNumber     String        @unique
  subtotal          Decimal       @db.Decimal(10, 2)
  tax               Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime?
  issuedAt          DateTime      @default(now())

  vendor          VendorProfile    @relation(fields: [vendorId], references: [id])
  application     Application      @relation(fields: [applicationId], references: [id])
  boothAssignment BoothAssignment? @relation(fields: [boothAssignmentId], references: [id])
  lineItems       InvoiceLineItem[]
  payments        Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// ─── INVOICE LINE ITEMS ──────────────────────────────────────

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

// ─── PAYMENTS ────────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  checkNumber     String?
  notes           String?
  recordedById    String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  recordedBy User?   @relation("RecordedPayments", fields: [recordedById], references: [id])
}

enum PaymentMethod {
  CHECK
  ZELLE
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── MESSAGING ───────────────────────────────────────────────

model Message {
  id          String        @id @default(uuid())
  vendorId    String
  sentById    String?
  channel     Channel
  subject     String?
  body        String
  status      MessageStatus @default(SENT)
  templateKey String?
  sentAt      DateTime      @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
  sentBy User?         @relation("SentMessages", fields: [sentById], references: [id])
}

model Notification {
  id           String        @id @default(uuid())
  vendorId     String
  triggerEvent String
  channel      Channel
  status       MessageStatus @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
}

enum Channel {
  EMAIL
  SMS
  BOTH
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}
