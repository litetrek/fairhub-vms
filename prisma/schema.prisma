// ============================================================
// VendorHub — Prisma Schema
// Updated: Stage 5 (Pre-Event Setup + Public Discovery)
// Changes from Stage 4:
//   - Event: added mapEmbedUrl, updatedAt
//   - BoothType: added whatsIncluded; added addOns relation (EventAddOn)
//   - New model: EventAddOn (setup-time add-ons tied to event/booth type)
//   - ApplicationAddOn: rerouted FK from BoothAddOn → EventAddOn
//   - Event: added addOns relation (EventAddOn)
//   - BoothAddOn (physical booth level) retained unchanged
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USERS & AUTH ────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?
  role          Role     @default(VENDOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  vendorProfile    VendorProfile?
  sentMessages     Message[]         @relation("SentMessages")
  approvalActions  ApprovalLog[]
  documentReviews  Document[]        @relation("ReviewedDocuments")
  boothAssignments BoothAssignment[] @relation("AssignedBoothAssignments")
  checkIns         BoothAssignment[] @relation("CheckedInAssignments")
  payments         Payment[]         @relation("RecordedPayments")
}

enum Role {
  VENDOR
  STAFF
  ADMIN
}

model VendorProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  businessName     String
  contactName      String
  businessType     String?
  address          String?
  city             String?
  state            String?
  zip              String?
  website          String?
  description      String?
  logoUrl          String?
  bannerImageUrl   String?
  galleryImages    String[] @default([])
  instagramUrl     String?
  facebookUrl      String?
  tiktokUrl        String?
  yearsInBusiness  Int?
  taxId            String?
  profileUpdatedAt DateTime?
  createdAt        DateTime  @default(now())

  user          User                @relation(fields: [userId], references: [id])
  applications  Application[]
  documents     Document[]
  messages      Message[]
  invoices      Invoice[]
  notifications Notification[]
  activityLogs  VendorActivityLog[]
}

// ─── EVENT ───────────────────────────────────────────────────

model Event {
  id                  String      @id @default(uuid())
  name                String
  description         String?
  eventDateStart      DateTime
  eventDateEnd        DateTime
  hours               String?
  location            String?
  address             String?
  city                String?
  state               String?
  mapEmbedUrl         String?     // NEW: Google Maps embed URL for public page
  publicSlug          String?     @unique
  bannerImageUrl      String?
  maxVendors          Int?
  applicationDeadline DateTime?
  status              EventStatus @default(DRAFT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt  // NEW

  applications Application[]
  booths       Booth[]
  boothTypes   BoothType[]
  weeks        EventWeek[]
  addOns       EventAddOn[]  // NEW
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

// ─── EVENT WEEKS ─────────────────────────────────────────────

model EventWeek {
  id        String   @id @default(uuid())
  eventId   String
  label     String
  startDate DateTime
  endDate   DateTime
  sortOrder Int      @default(0)

  event        Event             @relation(fields: [eventId], references: [id])
  applications ApplicationWeek[]
}

// ─── BOOTH TYPES ─────────────────────────────────────────────

model BoothType {
  id            String   @id @default(uuid())
  eventId       String
  name          String
  description   String?
  whatsIncluded String?  // NEW: freeform list of what comes with this booth type
  basePrice     Decimal  @db.Decimal(10, 2)
  sizeSqft      Int?
  totalCount    Int
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  event           Event                     @relation(fields: [eventId], references: [id])
  docRequirements BoothTypeDocRequirement[]
  applications    Application[]
  addOns          EventAddOn[]              // NEW
}

// ─── BOOTH TYPE DOCUMENT REQUIREMENTS ────────────────────────

model BoothTypeDocRequirement {
  id          String       @id @default(uuid())
  boothTypeId String
  docType     DocumentType
  required    Boolean      @default(true)
  notes       String?

  boothType BoothType @relation(fields: [boothTypeId], references: [id])

  @@unique([boothTypeId, docType])
}

// ─── EVENT ADD-ONS ───────────────────────────────────────────
// Setup-time add-ons (electricity, extra space, etc.) defined by staff
// during Pre-Event Setup. Vendors select these during the application.
// boothTypeId = null means the add-on is available for all booth types.

model EventAddOn {
  id          String   @id @default(uuid())
  eventId     String
  boothTypeId String?  // null = available for all booth types
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  event        Event              @relation(fields: [eventId], references: [id])
  boothType    BoothType?         @relation(fields: [boothTypeId], references: [id])
  selections   ApplicationAddOn[]
}

// ─── APPLICATIONS ────────────────────────────────────────────

model Application {
  id                 String            @id @default(uuid())
  vendorId           String
  eventId            String
  boothTypeId        String?
  status             ApplicationStatus @default(DRAFT)
  productDescription String?
  productCategory    String?
  needsElectricity   Boolean           @default(false)
  needsWater         Boolean           @default(false)
  specialRequests    String?
  rejectionNote      String?
  submittedAt        DateTime?
  updatedAt          DateTime          @default(now()) @updatedAt
  createdAt          DateTime          @default(now())

  vendor       VendorProfile      @relation(fields: [vendorId], references: [id])
  event        Event              @relation(fields: [eventId], references: [id])
  boothType    BoothType?         @relation(fields: [boothTypeId], references: [id])
  weeks        ApplicationWeek[]
  documents    Document[]
  approvalLogs ApprovalLog[]
  assignment   BoothAssignment?
  invoice      Invoice?
  addOns       ApplicationAddOn[]
  activityLogs VendorActivityLog[]
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CONDITIONALLY_APPROVED
  APPROVED
  REJECTED
  WITHDRAWN
}

// ─── APPLICATION WEEKS ───────────────────────────────────────

model ApplicationWeek {
  id            String @id @default(uuid())
  applicationId String
  eventWeekId   String

  application Application @relation(fields: [applicationId], references: [id])
  eventWeek   EventWeek   @relation(fields: [eventWeekId], references: [id])

  @@unique([applicationId, eventWeekId])
}

// ─── DOCUMENTS ───────────────────────────────────────────────

model Document {
  id            String         @id @default(uuid())
  vendorId      String
  applicationId String?
  docType       DocumentType
  fileName      String
  fileUrl       String
  status        DocumentStatus @default(PENDING)
  expiryDate    DateTime?
  reviewedById  String?
  uploadedAt    DateTime       @default(now())

  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  application Application?  @relation(fields: [applicationId], references: [id])
  reviewedBy  User?         @relation("ReviewedDocuments", fields: [reviewedById], references: [id])
}

enum DocumentType {
  BUSINESS_LICENSE
  SELLERS_PERMIT
  HEALTH_PERMIT
  FOOD_HANDLER
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// ─── APPROVAL LOG ────────────────────────────────────────────

model ApprovalLog {
  id            String   @id @default(uuid())
  applicationId String
  reviewedById  String
  action        String
  stage         String?
  notes         String?
  actionedAt    DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  reviewedBy  User        @relation(fields: [reviewedById], references: [id])
}

// ─── BOOTHS ──────────────────────────────────────────────────

model Booth {
  id          String      @id @default(uuid())
  eventId     String
  boothNumber String
  zone        String?
  sqft        Int?
  status      BoothStatus @default(AVAILABLE)
  mapX        Float?
  mapY        Float?
  notes       String?
  createdAt   DateTime    @default(now())

  event      Event            @relation(fields: [eventId], references: [id])
  addOns     BoothAddOn[]
  assignment BoothAssignment?

  @@unique([eventId, boothNumber])
}

enum BoothStatus {
  AVAILABLE
  ON_HOLD
  ASSIGNED
}

// ─── BOOTH ADD-ONS ───────────────────────────────────────────
// Physical booth-level add-ons (retained from Stage 4).
// Not used in the application flow — see EventAddOn for that.

model BoothAddOn {
  id      String  @id @default(uuid())
  boothId String
  name    String
  price   Decimal @db.Decimal(10, 2)

  booth Booth @relation(fields: [boothId], references: [id])
}

// ─── APPLICATION ADD-ONS ─────────────────────────────────────
// Records which EventAddOns a vendor selected on their application.

model ApplicationAddOn {
  id            String @id @default(uuid())
  applicationId String
  eventAddOnId  String  // CHANGED: was boothAddOnId → now eventAddOnId
  quantity      Int    @default(1)

  application Application @relation(fields: [applicationId], references: [id])
  eventAddOn  EventAddOn  @relation(fields: [eventAddOnId], references: [id])  // CHANGED

  @@unique([applicationId, eventAddOnId])  // CHANGED
}

// ─── BOOTH ASSIGNMENT ────────────────────────────────────────

model BoothAssignment {
  id            String    @id @default(uuid())
  boothId       String    @unique
  applicationId String    @unique
  assignedById  String
  assignedAt    DateTime  @default(now())
  notes         String?
  checkedIn     Boolean   @default(false)
  checkedInAt   DateTime?
  checkedInById String?

  booth       Booth       @relation(fields: [boothId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  assignedBy  User        @relation("AssignedBoothAssignments", fields: [assignedById], references: [id])
  checkedInBy User?       @relation("CheckedInAssignments", fields: [checkedInById], references: [id])
  invoice     Invoice?
}

// ─── INVOICES ────────────────────────────────────────────────

model Invoice {
  id                      String        @id @default(uuid())
  vendorId                String
  applicationId           String        @unique
  boothAssignmentId       String?       @unique
  invoiceNumber           String        @unique
  subtotal                Decimal       @db.Decimal(10, 2)
  tax                     Decimal       @default(0) @db.Decimal(10, 2)
  total                   Decimal       @db.Decimal(10, 2)
  status                  InvoiceStatus @default(DRAFT)
  dueDate                 DateTime?
  issuedAt                DateTime      @default(now())
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique

  vendor          VendorProfile     @relation(fields: [vendorId], references: [id])
  application     Application       @relation(fields: [applicationId], references: [id])
  boothAssignment BoothAssignment?  @relation(fields: [boothAssignmentId], references: [id])
  lineItems       InvoiceLineItem[]
  payments        Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// ─── INVOICE LINE ITEMS ──────────────────────────────────────

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

// ─── PAYMENTS ────────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  checkNumber     String?
  notes           String?
  recordedById    String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  recordedBy User?   @relation("RecordedPayments", fields: [recordedById], references: [id])
}

enum PaymentMethod {
  CHECK
  ZELLE
  CREDIT_CARD
  STRIPE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── MESSAGING ───────────────────────────────────────────────

model Message {
  id          String        @id @default(uuid())
  vendorId    String
  sentById    String?
  channel     Channel
  subject     String?
  body        String
  status      MessageStatus @default(SENT)
  templateKey String?
  sentAt      DateTime      @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
  sentBy User?         @relation("SentMessages", fields: [sentById], references: [id])
}

model Notification {
  id           String        @id @default(uuid())
  vendorId     String
  triggerEvent String
  channel      Channel
  status       MessageStatus @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
}

enum Channel {
  EMAIL
  SMS
  BOTH
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

// ─── VENDOR ACTIVITY LOG ─────────────────────────────────────
// applicationId = null → account-level action (visible to admin only)
// applicationId set   → application-level action (visible to staff + admin)

model VendorActivityLog {
  id            String   @id @default(uuid())
  vendorId      String
  applicationId String?
  action        String
  detail        String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  application Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
}
